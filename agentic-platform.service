[Unit]
Description=Agentic Platform MCP Server
After=network.target

[Service]
Type=simple
User=andy
WorkingDirectory=/home/andy/agentic-platform
ExecStart=/home/andy/agentic-platform/.venv/bin/python server.py
Restart=on-failure
RestartSec=5
Environment=MCP_PORT=8080

[Install]
WantedBy=multi-user.target
